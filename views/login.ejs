<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Sign in — OpenTraceBridge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=Archivo:wght@400;500;600;700;800&family=Spline+Sans+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/styles/admin.css">
  <style>
    /* ── Login-specific styles ── */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      font-family: 'Outfit', sans-serif;
      background: #080c1a;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      position: relative;
      overflow: hidden;
    }

    /* Animated gradient background */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 20% 20%, rgba(79,110,247,0.18) 0%, transparent 60%),
        radial-gradient(ellipse 60% 50% at 80% 70%, rgba(124,58,237,0.14) 0%, transparent 55%),
        radial-gradient(ellipse 50% 40% at 50% 100%, rgba(20,184,166,0.08) 0%, transparent 50%),
        linear-gradient(160deg, #080c1a 0%, #0a1030 50%, #080c1a 100%);
      animation: bgShift 12s ease-in-out infinite alternate;
      z-index: 0;
    }

    @keyframes bgShift {
      0%   { opacity: 1; filter: hue-rotate(0deg); }
      100% { opacity: 1; filter: hue-rotate(25deg); }
    }

    /* Floating orbs */
    .orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(80px);
      pointer-events: none;
      z-index: 0;
    }
    .orb-1 {
      width: 500px; height: 500px;
      background: rgba(79,110,247,0.12);
      top: -150px; left: -100px;
      animation: floatOrb1 18s ease-in-out infinite;
    }
    .orb-2 {
      width: 400px; height: 400px;
      background: rgba(124,58,237,0.10);
      bottom: -100px; right: -80px;
      animation: floatOrb2 22s ease-in-out infinite;
    }
    .orb-3 {
      width: 300px; height: 300px;
      background: rgba(20,184,166,0.07);
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      animation: floatOrb3 15s ease-in-out infinite;
    }

    @keyframes floatOrb1 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33%  { transform: translate(60px, 40px) scale(1.05); }
      66%  { transform: translate(-30px, 80px) scale(0.95); }
    }
    @keyframes floatOrb2 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50%  { transform: translate(-50px, -60px) scale(1.08); }
    }
    @keyframes floatOrb3 {
      0%, 100% { transform: translate(-50%, -50%) scale(1); }
      50%  { transform: translate(-50%, -50%) scale(1.15); }
    }

    /* Card */
    .login-card {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 420px;
      background: rgba(14, 21, 40, 0.80);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: 1.25rem;
      padding: 2.25rem 2rem;
      box-shadow:
        0 0 0 1px rgba(255,255,255,0.04) inset,
        0 30px 80px rgba(0,0,0,0.5),
        0 0 60px rgba(79,110,247,0.08);
      animation: cardIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    @keyframes cardIn {
      from { opacity: 0; transform: translateY(24px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* Brand */
    .login-brand {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      margin-bottom: 2rem;
    }

    .login-logo {
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 0.75rem;
      background: linear-gradient(135deg, #4f6ef7 0%, #7c3aed 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 0.9375rem;
      color: #fff;
      letter-spacing: -0.03em;
      box-shadow: 0 4px 16px rgba(79,110,247,0.4);
      flex-shrink: 0;
    }

    .login-brand-text h1 {
      font-size: 1rem;
      font-weight: 700;
      color: #e8eeff;
      letter-spacing: -0.02em;
      line-height: 1.2;
    }

    .login-brand-text p {
      font-size: 0.75rem;
      color: #6b7fa8;
      margin-top: 0.125rem;
    }

    /* Divider */
    .login-divider {
      height: 1px;
      background: rgba(255,255,255,0.06);
      margin-bottom: 1.75rem;
    }

    /* Field */
    .login-field {
      margin-bottom: 1rem;
    }

    .login-field label {
      display: block;
      font-size: 0.8125rem;
      font-weight: 600;
      color: #b0bfe8;
      letter-spacing: 0.01em;
      margin-bottom: 0.375rem;
    }

    .login-input-wrap {
      position: relative;
      display: flex;
      align-items: center;
    }

    .login-input-icon {
      position: absolute;
      left: 0.75rem;
      color: #3a4870;
      pointer-events: none;
      display: flex;
      align-items: center;
    }

    .login-input-wrap input {
      width: 100%;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: 0.75rem;
      padding: 0.6875rem 0.875rem 0.6875rem 2.625rem;
      font-size: 0.9375rem;
      font-family: 'Outfit', sans-serif;
      color: #e8eeff;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
      margin-top: 0;
    }

    .login-input-wrap input::placeholder { color: #3a4870; }

    .login-input-wrap input:focus {
      background: rgba(79,110,247,0.08);
      border-color: rgba(79,110,247,0.6);
      box-shadow: 0 0 0 3px rgba(79,110,247,0.15);
    }

    /* Error / warning */
    .login-alert {
      border-radius: 0.75rem;
      padding: 0.75rem 0.875rem;
      font-size: 0.8125rem;
      margin-bottom: 1rem;
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .login-alert-error {
      background: rgba(220,38,38,0.12);
      border: 1px solid rgba(220,38,38,0.3);
      color: #fca5a5;
    }
    .login-alert-warn {
      background: rgba(217,119,6,0.12);
      border: 1px solid rgba(217,119,6,0.3);
      color: #fcd34d;
    }

    /* Submit button */
    .login-btn {
      width: 100%;
      margin-top: 1.5rem;
      padding: 0.8125rem 1rem;
      border: none;
      border-radius: 0.75rem;
      background: linear-gradient(135deg, #4f6ef7 0%, #7c3aed 100%);
      color: #fff;
      font-family: 'Outfit', sans-serif;
      font-size: 0.9375rem;
      font-weight: 700;
      letter-spacing: 0.01em;
      cursor: pointer;
      box-shadow: 0 4px 20px rgba(79,110,247,0.35);
      transition: all 0.18s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      position: relative;
      overflow: hidden;
    }

    .login-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(255,255,255,0);
      transition: background 0.18s;
    }

    .login-btn:hover::before { background: rgba(255,255,255,0.06); }
    .login-btn:hover { box-shadow: 0 6px 28px rgba(79,110,247,0.5); transform: translateY(-1px); }
    .login-btn:active { transform: translateY(0) scale(0.98); box-shadow: 0 2px 10px rgba(79,110,247,0.3); }
    .login-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
      box-shadow: none;
    }

    /* Footer */
    .login-footer {
      margin-top: 1.75rem;
      text-align: center;
      font-size: 0.75rem;
      color: #3a4870;
    }
  </style>
</head>
<body>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <form method="post" action="/admin/login" class="login-card">
    <input type="hidden" name="next" value="<%= next %>">

    <div class="login-brand">
      <div class="login-logo">OT</div>
      <div class="login-brand-text">
        <h1>OpenTraceBridge</h1>
        <p>Admin console · Private access</p>
      </div>
    </div>

    <div class="login-divider"></div>

    <% if (!configured) { %>
      <div class="login-alert login-alert-warn">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" style="flex-shrink:0;margin-top:1px"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
        <span>Admin credentials not configured. Set <code style="background:rgba(255,255,255,0.1);border:none;color:inherit;padding:0.1em 0.3em;border-radius:0.25rem">ADMIN_USERNAME</code> and <code style="background:rgba(255,255,255,0.1);border:none;color:inherit;padding:0.1em 0.3em;border-radius:0.25rem">ADMIN_PASSWORD</code> in your environment.</span>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="login-alert login-alert-error" role="alert">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" style="flex-shrink:0;margin-top:1px"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/></svg>
        <span><%= error %></span>
      </div>
    <% } %>

    <div class="login-field">
      <label for="username">Username</label>
      <div class="login-input-wrap">
        <span class="login-input-icon">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor"><path d="M10 8a3 3 0 100-6 3 3 0 000 6zM3.465 14.493a1.23 1.23 0 00.41 1.412A9.957 9.957 0 0010 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 00-13.074.003z"/></svg>
        </span>
        <input id="username" name="username" type="text"
               autocomplete="username" required autofocus
               placeholder="Enter your username">
      </div>
    </div>

    <div class="login-field">
      <label for="password">Password</label>
      <div class="login-input-wrap">
        <span class="login-input-icon">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd"/></svg>
        </span>
        <input id="password" name="password" type="password"
               autocomplete="current-password" required
               placeholder="Enter your password">
      </div>
    </div>

    <button type="submit" class="login-btn" <%= configured ? '' : 'disabled' %>>
      <span>Sign in</span>
      <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
    </button>

    <div class="login-footer">
      OpenTraceBridge &mdash; Secure Admin Console
    </div>
  </form>
</body>
</html>
