<fieldset style="border-radius:0.875rem;border:1px solid var(--color-border);background:var(--color-panel-alt);padding:1rem" data-row>
  <input type="hidden" name="repos[<%= i %>][id]" value="<%= r.id || '' %>">

  <div class="form-grid">
    <div>
      <label>Git URL</label>
      <input type="text" name="repos[<%= i %>][git_url]" value="<%= r.git_url || '' %>"
             placeholder="https://github.com/org/repo.git  or  git@github.com:org/repo.git">
    </div>
    <div>
      <label>Auth type</label>
      <div class="segmented" data-auth-type-group>
        <label class="segmented-option">
          <input type="radio" name="repos[<%= i %>][auth_type]" value="none"
                 <%= r.auth_type === 'none' || !r.auth_type ? 'checked' : '' %>>
          <span>None</span>
        </label>
        <label class="segmented-option">
          <input type="radio" name="repos[<%= i %>][auth_type]" value="https-token"
                 <%= r.auth_type === 'https-token' ? 'checked' : '' %>>
          <span>Token</span>
        </label>
        <label class="segmented-option">
          <input type="radio" name="repos[<%= i %>][auth_type]" value="ssh"
                 <%= r.auth_type === 'ssh' ? 'checked' : '' %>>
          <span>SSH</span>
        </label>
      </div>
    </div>
    <div>
      <label>Branch</label>
      <input type="text" name="repos[<%= i %>][branch]" value="<%= r.branch || 'main' %>">
    </div>
  </div>

  <!-- HTTPS Token (shown only when auth_type = https-token) -->
  <div data-token-wrap style="margin-top:0.875rem;display:none">
    <label>Personal access token</label>
    <input type="password" name="repos[<%= i %>][token]" value="" autocomplete="new-password" data-token-input
           placeholder="<%= r.id ? 'Leave blank to keep the current token' : 'ghp_xxxxxxxxxxxx' %>">
    <p class="field-help">GitHub/GitLab personal access token with <code>read:repo</code> scope.</p>
  </div>

  <!-- SSH Key (shown only when auth_type = ssh) -->
  <div data-ssh-wrap style="margin-top:0.875rem;display:none">
    <label>SSH private key (PEM or OpenSSH format)</label>
    <textarea name="repos[<%= i %>][ssh_key]" data-ssh-key-input
              placeholder="<%= r.id ? 'Leave blank to keep the current key' : '-----BEGIN OPENSSH PRIVATE KEY-----\n...' %>"></textarea>
    <p class="field-help">Paste the full private key including header/footer lines.</p>
  </div>

  <!-- Status + Remove -->
  <div style="margin-top:0.875rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap">
    <div data-repo-status="<%= r.id %>">
      <% if (r.id && r.sync_status) { %>
        <span class="status-badge <%= syncBadgeClass[r.sync_status] || 'status-muted' %>"><%= r.sync_status %></span>
        <% if (r.synced_at) { %><span style="margin-left:0.5rem;font-size:0.75rem;color:var(--color-ink-500)"><%= r.synced_at %></span><% } %>
        <% if (r.sync_status === 'error' && r.sync_error) { %>
          <div style="margin-top:0.25rem;max-width:36rem;font-size:0.75rem;color:var(--color-danger);overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= r.sync_error %>"><%= r.sync_error %></div>
        <% } %>
      <% } else { %>
        <span style="font-size:0.75rem;color:var(--color-ink-500)">Not saved yet</span>
      <% } %>
    </div>
    <button type="button" class="btn btn-danger" data-remove>Remove</button>
  </div>
</fieldset>
