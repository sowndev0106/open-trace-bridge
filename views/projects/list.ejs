<%- include('../layout-head') %>

<%
  const syncBadgeClass = { success: 'status-active', error: 'status-error', syncing: 'status-syncing', pending: 'status-muted' };
%>

<section style="margin-bottom:1.5rem;display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:1rem">
  <div>
    <p class="page-kicker">Project registry</p>
    <h1 class="page-title">Projects</h1>
    <p class="page-subtitle">Manage Teams event endpoints, agent workspaces, repositories, and internal API groups.</p>
  </div>
  <a href="/admin/projects/new" class="btn btn-primary">
    <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z"/></svg>
    New project
  </a>
</section>

<!-- Quick stats -->
<section style="margin-bottom:1.5rem;display:grid;gap:0.875rem;grid-template-columns:repeat(3,1fr)">
  <div class="panel panel-body">
    <p style="font-size:0.75rem;font-weight:600;color:var(--color-ink-500);text-transform:uppercase;letter-spacing:0.05em">Total projects</p>
    <p style="margin-top:0.5rem;font-size:1.75rem;font-weight:800;letter-spacing:-0.04em;color:var(--color-ink-950)"><%= projects.length %></p>
  </div>
  <div class="panel panel-body">
    <p style="font-size:0.75rem;font-weight:600;color:var(--color-ink-500);text-transform:uppercase;letter-spacing:0.05em">Event endpoint</p>
    <p style="margin-top:0.5rem;font-family:var(--font-mono);font-size:0.8125rem;color:var(--color-brand)"><code style="background:none;border:none;padding:0;color:inherit">/api/events/:slug</code></p>
  </div>
  <div class="panel panel-body">
    <p style="font-size:0.75rem;font-weight:600;color:var(--color-ink-500);text-transform:uppercase;letter-spacing:0.05em">Admin scope</p>
    <p style="margin-top:0.5rem;font-size:0.875rem;font-weight:600;color:var(--color-ink-950)">Private console</p>
  </div>
</section>

<% if (!projects.length) { %>
  <section class="empty-state">
    <div style="width:3.5rem;height:3.5rem;border-radius:1rem;background:var(--grad-brand);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;box-shadow:0 4px 20px var(--color-brand-glow)">
      <svg width="22" height="22" viewBox="0 0 20 20" fill="white"><path d="M7 3a1 1 0 000 2h6a1 1 0 100-2H7zM4 7a1 1 0 011-1h10a1 1 0 110 2H5a1 1 0 01-1-1zM2 11a2 2 0 012-2h12a2 2 0 012 2v4a2 2 0 01-2 2H4a2 2 0 01-2-2v-4z"/></svg>
    </div>
    <h2 style="font-size:1.0625rem;font-weight:700;color:var(--color-ink-950)">No projects yet</h2>
    <p style="margin-top:0.5rem;font-size:0.875rem;color:var(--color-ink-500)">Create your first project to start receiving Teams events and routing investigations.</p>
    <a href="/admin/projects/new" class="btn btn-primary" style="margin-top:1.5rem">
      <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z"/></svg>
      New project
    </a>
  </section>
<% } else { %>

<section class="table-shell">
  <div class="table-scroll">
    <table class="data-table">
      <thead>
        <tr>
          <th>Project</th>
          <th>Keyword</th>
          <th>Event URL</th>
          <th>Source sync</th>
          <th style="text-align:right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% for (const p of projects) { %>
        <tr>
          <td>
            <div style="font-weight:700;color:var(--color-ink-950)"><%= p.name %></div>
            <div style="margin-top:0.125rem;font-size:0.75rem;font-family:var(--font-mono);color:var(--color-ink-500)"><%= p.slug %></div>
          </td>
          <td>
            <% if (p.keyword) { %>
              <span class="status-badge status-muted"><%= p.keyword %></span>
            <% } else { %>
              <span style="font-size:0.8125rem;color:var(--color-ink-300)">—</span>
            <% } %>
          </td>
          <td>
            <code style="font-size:0.75rem">/api/events/<%= p.slug %></code>
          </td>
          <td>
            <% if (p.repo_count) { %>
              <span class="status-badge <%= syncBadgeClass[p.sync_status] || 'status-muted' %>" data-project-sync><%= p.sync_status %></span>
              <% if (p.synced_at) { %><div style="margin-top:0.25rem;font-size:0.6875rem;color:var(--color-ink-500)"><%= p.synced_at %></div><% } %>
            <% } else { %>
              <span style="font-size:0.8125rem;color:var(--color-ink-300)">No repos</span>
            <% } %>
          </td>
          <td>
            <div style="display:flex;justify-content:flex-end;align-items:center;gap:0.375rem">
              <!-- Primary action: Chat -->
              <a class="btn btn-primary" href="/admin/projects/<%= p.id %>/chat" style="padding:0 0.75rem">
                <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor"><path d="M3.505 2.365A41.369 41.369 0 019 2c1.863 0 3.697.124 5.495.365 1.247.167 2.18 1.108 2.435 2.268a4.45 4.45 0 00-.577-.069 43.141 43.141 0 00-4.706 0C9.229 4.696 7.5 6.727 7.5 8.998v2.24c0 1.413.67 2.735 1.76 3.562l-2.98 2.98A.75.75 0 015 17.25v-3.443c-.501-.048-1-.106-1.495-.172C2.033 13.438 1 12.162 1 10.72V5.28c0-1.441 1.033-2.717 2.505-2.914z"/><path d="M14 6c-.762 0-1.52.02-2.271.062C10.157 6.148 9 7.434 9 8.998v2.24c0 1.564 1.157 2.85 2.729 2.936.509.028 1.019.042 1.532.042.846 0 1.683-.034 2.505-.103l2.98 2.98A.75.75 0 0020 16.25v-3.22c.187-.726.282-1.487.282-2.271 0-1.565-1.157-2.85-2.729-2.936A41.645 41.645 0 0014 6z"/></svg>
                Chat
              </a>
              <a class="btn btn-secondary" href="/admin/projects/<%= p.id %>/opencode" style="padding:0 0.625rem" title="OpenCode UI">
                <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6.28 5.22a.75.75 0 010 1.06L2.56 10l3.72 3.72a.75.75 0 01-1.06 1.06L.97 10.53a.75.75 0 010-1.06l4.25-4.25a.75.75 0 011.06 0zm7.44 0a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06L17.44 10l-3.72-3.72a.75.75 0 010-1.06zM11.377 2.011a.75.75 0 01.612.867l-2.5 14.5a.75.75 0 01-1.478-.255l2.5-14.5a.75.75 0 01.866-.612z" clip-rule="evenodd"/></svg>
              </a>
              <a class="btn btn-secondary" href="/admin/projects/<%= p.id %>/conversations" style="padding:0 0.625rem" title="View logs">
                <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>
              </a>
              <a class="btn btn-secondary" href="/admin/projects/<%= p.id %>/edit" style="padding:0 0.625rem" title="Edit">
                <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor"><path d="M2.695 14.763l-1.262 3.154a.5.5 0 00.65.65l3.155-1.262a4 4 0 001.343-.885L17.5 5.5a2.121 2.121 0 00-3-3L3.58 13.42a4 4 0 00-.885 1.343z"/></svg>
              </a>
              <form class="inline-form" method="post" action="/admin/projects/<%= p.id %>/delete"
                    onsubmit="return confirm('Delete project <%= p.slug %>? This cannot be undone.')">
                <button class="btn btn-danger" type="submit" style="padding:0 0.625rem" title="Delete">
                  <svg width="13" height="13" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.52.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 00-1.5.06l.3 7.5a.75.75 0 101.5-.06l-.3-7.5zm4.34.06a.75.75 0 10-1.5-.06l-.3 7.5a.75.75 0 101.5.06l.3-7.5z" clip-rule="evenodd"/></svg>
                </button>
              </form>
            </div>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>

<% } %>

<%- include('../layout-foot') %>
