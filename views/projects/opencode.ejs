<%- include('../layout-head') %>

<section style="display:flex;flex-direction:column;min-height:calc(100vh - 9rem)">

  <!-- Header -->
  <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:1rem;flex-wrap:wrap">
    <div style="display:flex;align-items:center;gap:0.75rem">
      <a class="btn btn-secondary" href="/admin/projects/<%= project.id %>/edit" style="padding:0 0.75rem">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd"/></svg>
        Back
      </a>
      <div>
        <div style="display:flex;align-items:center;gap:0.625rem">
          <h1 style="font-size:1.125rem;font-weight:700;letter-spacing:-0.02em;color:var(--color-ink-950)"><%= project.name %></h1>
          <span style="font-size:0.75rem;padding:0.2rem 0.6rem;border-radius:9999px;background:color-mix(in srgb,var(--color-success) 12%,transparent);color:var(--color-success);font-weight:600;border:1px solid color-mix(in srgb,var(--color-success) 25%,transparent)">OpenCode UI</span>
        </div>
        <p style="font-size:0.75rem;color:var(--color-ink-500);margin-top:0.125rem">
          Full OpenCode interface. Open sessions under <code style="background:none;border:none;padding:0"><%= 'workspaces/' + project.slug %></code> to stay inside this project.
        </p>
      </div>
    </div>
    <a class="btn btn-secondary" id="open-new-tab" href="#" target="_blank" rel="noopener">Open in new tab</a>
  </div>

  <!-- Embedded OpenCode UI -->
  <div class="panel" style="flex:1;padding:0;overflow:hidden;display:flex">
    <iframe id="opencode-frame" title="OpenCode UI"
      style="flex:1;width:100%;min-height:32rem;border:0;background:#fff"></iframe>
  </div>
</section>

<script>
(function () {
  var port = <%= opencodeUiPort %>;
  var base = location.protocol + '//' + location.hostname + ':' + port + '/';
  document.getElementById('opencode-frame').src = base;
  document.getElementById('open-new-tab').href = base;
})();
</script>
<%- include('../layout-foot') %>
