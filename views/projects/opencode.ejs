<%- include('../layout-head') %>

<section style="display:flex;flex-direction:column;min-height:calc(100vh - 9rem)">

  <div style="margin-bottom:0.5rem">
    <p class="kicker"><a href="/admin/projects/<%= project.id %>/edit">← Projects</a> / Workspace</p>
    <div style="display:flex;align-items:baseline;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-top:0.375rem">
      <h1 class="page-title" style="font-size:1.75rem"><%= project.name %></h1>
      <a class="btn btn-secondary" id="open-new-tab" href="#" target="_blank" rel="noopener">Open in new tab ↗</a>
    </div>
  </div>

  <%- include('_workspace-tabs', { project: project, active: 'opencode' }) %>

  <!-- Embedded OpenCode UI -->
  <div class="panel" style="flex:1;padding:0;overflow:hidden;display:flex">
    <iframe id="opencode-frame" title="OpenCode UI"
      style="flex:1;width:100%;min-height:32rem;border:0;background:#fff"></iframe>
  </div>
</section>

<script>
(function () {
  var port = <%= opencodeUiPort %>;
  var base = location.protocol + '//' + location.hostname + ':' + port + '/';
  document.getElementById('opencode-frame').src = base;
  document.getElementById('open-new-tab').href = base;
})();
</script>
<%- include('../layout-foot') %>
