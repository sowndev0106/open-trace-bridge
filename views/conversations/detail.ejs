<%- include('../layout-head') %>

<section class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <p class="page-kicker"><%= project.name %></p>
    <h1 class="page-title">Conversation #<%= conv.id %></h1>
    <p class="page-subtitle">Session <code><%= conv.opencode_session_id || '-' %></code> with status <span class="status-badge <%= conv.status === 'active' ? 'status-active' : 'status-muted' %>"><%= conv.status %></span></p>
  </div>
  <a href="/admin/projects/<%= project.id %>/conversations" class="btn btn-secondary">Back to audit</a>
</section>

<section class="panel">
  <div class="panel-body">
    <div class="message-timeline space-y-5">
      <% for (const m of messages) { %>
        <% const isInbound = m.direction === 'in'; %>
        <article class="flex <%= isInbound ? 'justify-start' : 'justify-end' %>">
          <div class="max-w-3xl rounded-lg border <%= isInbound ? 'border-line bg-slate-50/50 dark:bg-slate-900/40' : 'border-blue-200/60 bg-blue-50/50 dark:border-blue-900/40 dark:bg-blue-950/30' %> p-4">
            <div class="mb-2 flex flex-wrap items-center gap-2">
              <strong class="text-sm text-ink-950"><%= isInbound ? (m.user_name || 'user') : 'bot' %></strong>
              <small class="text-xs text-ink-500"><%= m.created_at %></small>
            </div>
            <div class="whitespace-pre-wrap text-sm leading-6 text-ink-700"><%= m.content %></div>
          </div>
        </article>
      <% } %>
    </div>
  </div>
</section>

<section class="panel mt-6">
  <div class="panel-body">
    <h2 class="section-heading mb-4">API calls</h2>
    <% if (apiCalls && apiCalls.length) { %>
      <%- include('_api-calls-table', { apiCalls, showConversation: false }) %>
    <% } else { %>
      <div class="rounded-lg border border-dashed border-line bg-slate-50 px-4 py-5 text-sm text-ink-500">This conversation has not made any API calls.</div>
    <% } %>
  </div>
</section>

<%- include('../layout-foot') %>
