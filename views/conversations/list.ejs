<%- include('../layout-head') %>

<section style="margin-bottom:1.5rem;display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:1rem">
  <div>
    <p class="page-kicker"><%= project.name %></p>
    <h1 class="page-title">Conversations</h1>
    <p class="page-subtitle">Teams conversation sessions and internal API call audit for this project.</p>
  </div>
  <a href="/admin/projects/<%= project.id %>/edit" class="btn btn-secondary">
    <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd"/></svg>
    Back to project
  </a>
</section>

<!-- Conversation sessions -->
<section id="chat-history" class="table-shell" style="margin-bottom:1.25rem">
  <div style="padding:1rem 1.25rem;border-bottom:1px solid var(--color-border);display:flex;align-items:center;gap:0.75rem">
    <div style="width:0.375rem;height:1.125rem;border-radius:9999px;background:var(--grad-brand)"></div>
    <h2 class="section-heading">Conversation sessions</h2>
  </div>
  <div class="table-scroll">
    <table class="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Teams conversation</th>
          <th>OpenCode session</th>
          <th>Status</th>
          <th>Updated</th>
        </tr>
      </thead>
      <tbody>
        <% if (!conversations.length) { %>
          <tr><td colspan="5" style="text-align:center;color:var(--color-ink-500);padding:2.5rem">No conversations yet.</td></tr>
        <% } %>
        <% for (const c of conversations) { %>
        <tr>
          <td>
            <a style="font-weight:700;color:var(--color-brand);text-decoration:none"
               href="/admin/conversations/<%= c.id %>">#<%= c.id %></a>
          </td>
          <td style="max-width:18rem">
            <span style="display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:var(--font-mono);font-size:0.75rem;color:var(--color-ink-500)"
                  title="<%= c.teams_conversation_id %>">
              <%= c.teams_conversation_id %>
            </span>
          </td>
          <td><code style="font-size:0.75rem"><%= c.opencode_session_id || '—' %></code></td>
          <td><span class="status-badge <%= c.status === 'active' ? 'status-active' : 'status-muted' %>"><%= c.status %></span></td>
          <td style="font-size:0.8125rem;color:var(--color-ink-500)"><%= c.updated_at %></td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>

<!-- API calls -->
<section id="api-calls" class="table-shell">
  <div style="padding:1rem 1.25rem;border-bottom:1px solid var(--color-border);display:flex;align-items:center;gap:0.75rem">
    <div style="width:0.375rem;height:1.125rem;border-radius:9999px;background:linear-gradient(180deg,#f97316,#ef4444)"></div>
    <h2 class="section-heading">Latest API calls</h2>
  </div>
  <div style="padding:1rem">
    <%- include('_api-calls-table', { apiCalls, showConversation: true }) %>
  </div>
</section>

<%- include('../layout-foot') %>
