<%- include('../layout-head', { layoutShell: 'index', sidebarProjects: allProjects }) %>

<section style="margin-bottom:2rem;display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:1rem;border-bottom:1px solid var(--color-border);padding-bottom:1.125rem">
  <div>
    <p class="kicker">System ledger</p>
    <h1 class="page-title">The week in <em style="font-style:italic;color:var(--color-brand)">numbers</em></h1>
  </div>
  <div style="display:flex;align-items:baseline;gap:1.25rem;flex-wrap:wrap">
    <div style="display:flex;gap:0.875rem;font-family:var(--font-mono);font-size:0.71875rem">
      <% [7, 30, 90].forEach(function(d) { %>
        <a href="?days=<%= d %><%= filterProjectId ? '&project=' + filterProjectId : '' %>"
           style="text-decoration:none;padding-bottom:0.1875rem;<%= days === d
             ? 'color:var(--color-ink-950);border-bottom:2px solid var(--color-brand)'
             : 'color:var(--color-ink-300)' %>"><%= d %>D</a>
      <% }); %>
    </div>
    <form method="get" style="display:flex">
      <input type="hidden" name="days" value="<%= days %>">
      <select name="project" onchange="this.form.submit()" style="width:12rem;margin-top:0">
        <option value="">All projects ▾</option>
        <% allProjects.forEach(function(p) { %>
          <option value="<%= p.id %>" <%= filterProjectId === p.id ? 'selected' : '' %>><%= p.name %></option>
        <% }); %>
      </select>
    </form>
  </div>
</section>

<!-- Metric ledger row -->
<section style="margin-bottom:1.5rem;display:grid;grid-template-columns:repeat(2,1fr);border-bottom:1px solid var(--color-border)">
  <style>
    @media(min-width:640px){#metric-grid{grid-template-columns:repeat(3,1fr)}}
    @media(min-width:1024px){#metric-grid{grid-template-columns:repeat(6,1fr)}}
  </style>
  <div id="metric-grid" style="display:contents">

    <div style="padding:1.25rem 1.125rem 1.125rem 0;border-right:1px solid var(--color-border)">
      <p class="kicker">Questions</p>
      <p style="margin-top:0.625rem;font-family:var(--font-serif);font-size:2rem;font-weight:500;line-height:1;color:var(--color-ink-950)"><%= totals.questions.toLocaleString() %></p>
      <p style="margin-top:0.5rem;font-family:var(--font-mono);font-size:0.65625rem;color:var(--color-ok)">+12% W/W</p>
    </div>

    <div style="padding:1.25rem 1.125rem;border-right:1px solid var(--color-border)">
      <p class="kicker">Avg response</p>
      <p style="margin-top:0.625rem;font-family:var(--font-serif);font-size:2rem;font-weight:500;line-height:1;color:var(--color-ink-950)">
        <%= totals.totalRuns ? Math.round(perProject.reduce((a,r)=>a+(r.avgDurationMs||0)*r.totalRuns,0)/totals.totalRuns).toLocaleString()+'ms' : 'n/a' %>
      </p>
    </div>

    <div style="padding:1.25rem 1.125rem;border-right:1px solid var(--color-border)">
      <p class="kicker">Error rate</p>
      <p style="margin-top:0.625rem;font-family:var(--font-serif);font-size:2rem;font-weight:500;line-height:1;color:<%= totals.totalRuns && (100*totals.errorRuns/totals.totalRuns) > 0 ? 'var(--color-danger)' : 'var(--color-ink-950)' %>">
        <%= totals.totalRuns ? (100*totals.errorRuns/totals.totalRuns).toFixed(1)+'%' : 'n/a' %>
      </p>
    </div>

    <div style="padding:1.25rem 1.125rem;border-right:1px solid var(--color-border)">
      <p class="kicker">API calls</p>
      <p style="margin-top:0.625rem;font-family:var(--font-serif);font-size:2rem;font-weight:500;line-height:1;color:var(--color-ink-950)"><%= totals.apiCallCount.toLocaleString() %></p>
    </div>

    <div style="padding:1.25rem 1.125rem;border-right:1px solid var(--color-border)">
      <p class="kicker">Tokens</p>
      <p style="margin-top:0.625rem;font-family:var(--font-serif);font-size:2rem;font-weight:500;line-height:1;color:var(--color-ink-950)">
        <%= (totals.totalTokensInput+totals.totalTokensOutput) ? (totals.totalTokensInput+totals.totalTokensOutput).toLocaleString() : 'n/a' %>
      </p>
      <p style="margin-top:0.5rem;font-family:var(--font-mono);font-size:0.65625rem;color:var(--color-ink-300)">IN <%= totals.totalTokensInput.toLocaleString() %> / OUT <%= totals.totalTokensOutput.toLocaleString() %></p>
    </div>

    <div style="padding:1.25rem 0 1.125rem 1.125rem">
      <p class="kicker">Total cost</p>
      <p style="margin-top:0.625rem;font-family:var(--font-serif);font-size:2rem;font-weight:500;line-height:1;color:var(--color-ink-950)">
        <%= totals.totalCostUsd ? '$'+totals.totalCostUsd.toFixed(4) : 'n/a' %>
      </p>
    </div>

  </div><!-- /metric-grid -->
</section>

<!-- Chart -->
<section style="margin-bottom:1.5rem;
padding-top:1.375rem;border-top:1px solid var(--color-border)">
  <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.25rem;gap:1rem;flex-wrap:wrap">
    <div>
      <p style="font-size:0.9375rem;font-weight:700;color:var(--color-ink-950);letter-spacing:-0.01em">Questions per day</p>
      <p style="font-size:0.75rem;color:var(--color-ink-500);margin-top:0.25rem">Timeline of incoming questions over the selected range</p>
    </div>
    <div class="kicker">Peak <%= chart.length ? Math.max(...chart.map(r=>r.count)) : 0 %></div>
  </div>

  <% if (!chart.length) { %>
    <div style="padding:3.5rem 1rem;text-align:center">
      <div style="width:3rem;height:3rem;border-radius:0.875rem;background:var(--color-panel-alt);border:1px solid var(--color-border);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="var(--color-ink-300)"><path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zm6-4a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zm6-3a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"/></svg>
      </div>
      <p style="font-size:0.875rem;color:var(--color-ink-500)">No questions recorded in this range.</p>
    </div>
  <% } else {
    const counts  = chart.map(r => r.count);
    const maxVal  = Math.max(...counts, 1);
    const W = 1000, H = 280;
    const PL = 52, PR = 24, PT = 20, PB = 44;
    const CW = W - PL - PR, CH = H - PT - PB;

    // Build smooth bezier path
    function getX(i) { return PL + (chart.length > 1 ? (i/(chart.length-1))*CW : CW/2); }
    function getY(v) { return PT + CH - (v/maxVal)*CH; }

    let pathD = '', areaD = '';
    if (chart.length === 1) {
      const x = getX(0), y = getY(chart[0].count);
      pathD = `M ${x-2} ${y} L ${x+2} ${y}`;
      areaD = `M ${x-2} ${PT+CH} L ${x-2} ${y} L ${x+2} ${y} L ${x+2} ${PT+CH} Z`;
    } else {
      // Smooth cubic bezier between points
      const pts = chart.map((r,i) => ({ x: getX(i), y: getY(r.count) }));
      pathD = `M ${pts[0].x} ${pts[0].y}`;
      for (let i = 1; i < pts.length; i++) {
        const cpx1 = pts[i-1].x + (pts[i].x - pts[i-1].x) * 0.4;
        const cpy1 = pts[i-1].y;
        const cpx2 = pts[i].x   - (pts[i].x - pts[i-1].x) * 0.4;
        const cpy2 = pts[i].y;
        pathD += ` C ${cpx1} ${cpy1} ${cpx2} ${cpy2} ${pts[i].x} ${pts[i].y}`;
      }
      areaD = `M ${pts[0].x} ${PT+CH} L ${pts[0].x} ${pts[0].y}`;
      for (let i = 1; i < pts.length; i++) {
        const cpx1 = pts[i-1].x + (pts[i].x - pts[i-1].x) * 0.4;
        const cpy1 = pts[i-1].y;
        const cpx2 = pts[i].x   - (pts[i].x - pts[i-1].x) * 0.4;
        const cpy2 = pts[i].y;
        areaD += ` C ${cpx1} ${cpy1} ${cpx2} ${cpy2} ${pts[i].x} ${pts[i].y}`;
      }
      areaD += ` L ${pts[pts.length-1].x} ${PT+CH} Z`;
    }

    const labelStep = Math.max(1, Math.ceil(chart.length / 10));
  %>
  <div style="position:relative;width:100%;overflow:hidden">
    <!-- Tooltip overlay (JS driven) -->
    <div id="chart-tooltip" style="
      position:absolute;pointer-events:none;opacity:0;transition:opacity 0.15s;
      background:var(--color-panel-raised);border:1px solid var(--color-border-strong);
      border-radius:0.5rem;padding:0.4375rem 0.75rem;font-size:0.75rem;font-weight:600;
      color:var(--color-ink-950);box-shadow:0 4px 16px rgba(0,0,0,0.15);
      white-space:nowrap;z-index:10;transform:translate(-50%,-110%);
    "></div>

    <svg id="chart-svg" viewBox="0 0 <%= W %> <%= H %>" style="width:100%;height:auto;overflow:visible;display:block;cursor:crosshair">
      <defs>
        <clipPath id="chart-clip">
          <rect x="<%= PL %>" y="<%= PT %>" width="<%= CW %>" height="<%= CH %>"/>
        </clipPath>
      </defs>

      <!-- Y-axis grid lines -->
      <% [0, 0.25, 0.5, 0.75, 1].forEach(function(pct) {
           const y   = PT + CH - pct * CH;
           const val = Math.round(pct * maxVal);
      %>
        <line x1="<%= PL %>" y1="<%= y %>" x2="<%= W-PR %>" y2="<%= y %>"
              stroke="var(--color-border)" stroke-width="1"
              stroke-dasharray="<%= pct === 0 || pct === 1 ? 'none' : '4,5' %>"/>
        <text x="<%= PL - 8 %>" y="<%= y + 4 %>"
              fill="var(--color-ink-500)" font-size="11"
              text-anchor="end" font-family="var(--font-mono)"><%= val %></text>
      <% }); %>

      <!-- Line, no fill, no glow -->
      <path d="<%= pathD %>" fill="none"
            stroke="var(--color-ink-950)" stroke-width="1.5"
            stroke-linecap="round" stroke-linejoin="round"
            clip-path="url(#chart-clip)"/>

      <!-- X-axis labels -->
      <% chart.forEach(function(row, idx) {
           if (idx % labelStep !== 0 && idx !== chart.length-1) return;
           const x = getX(idx);
           const d = new Date(row.day);
           const label = d.toLocaleDateString('en-US',{month:'short',day:'2-digit'});
      %>
        <text x="<%= x %>" y="<%= PT + CH + 28 %>"
              fill="var(--color-ink-500)" font-size="11"
              text-anchor="middle" font-family="var(--font-sans)"><%= label %></text>
      <% }); %>

      <!-- Points: small ink dots, one larger accent dot at the peak (also hover hit-targets) -->
      <% var _peak = chart.length ? Math.max(...chart.map(r=>r.count)) : null; %>
      <% chart.forEach(function(row, idx) {
           const x = getX(idx), y = getY(row.count);
           const dateStr = new Date(row.day).toLocaleDateString('en-US',{month:'short',day:'2-digit',year:'numeric'});
      %>
        <g class="chart-point"
           data-x="<%= x %>" data-y="<%= y %>"
           data-label="<%= dateStr %>: <%= row.count %> question<%= row.count !== 1 ? 's' : '' %>">
          <circle cx="<%= x %>" cy="<%= y %>" r="14" fill="transparent"/>
          <% if (row.count === _peak) { %>
            <circle class="chart-dot" data-peak="true" cx="<%= x %>" cy="<%= y %>" r="4"
                    fill="var(--color-brand)" style="transition:r 0.15s"/>
            <text x="<%= x %>" y="<%= y - 12 %>" text-anchor="middle" font-family="Spline Sans Mono" font-size="10" fill="var(--color-brand)"><%= row.count %></text>
          <% } else { %>
            <circle class="chart-dot" cx="<%= x %>" cy="<%= y %>" r="2.5"
                    fill="var(--color-canvas)" stroke="var(--color-ink-950)" stroke-width="1.5"
                    style="transition:r 0.15s"/>
          <% } %>
        </g>
      <% }); %>
    </svg>
  </div>

  <script>
  (function() {
    var svg     = document.getElementById('chart-svg');
    var tooltip = document.getElementById('chart-tooltip');
    if (!svg || !tooltip) return;

    svg.querySelectorAll('.chart-point').forEach(function(g) {
      var dot = g.querySelector('.chart-dot');
      g.addEventListener('mouseenter', function() {
        var svgRect = svg.getBoundingClientRect();
        var vbW = 1000, vbH = 280;
        var scaleX = svgRect.width  / vbW;
        var scaleY = svgRect.height / vbH;
        var x = parseFloat(g.dataset.x) * scaleX;
        var y = parseFloat(g.dataset.y) * scaleY;

        tooltip.textContent = g.dataset.label;
        tooltip.style.left  = x + 'px';
        tooltip.style.top   = y + 'px';
        tooltip.style.opacity = '1';

        dot.setAttribute('r', '5.5');
        dot.setAttribute('fill', 'var(--color-brand)');
        dot.setAttribute('stroke', 'var(--color-canvas)');
      });
      g.addEventListener('mouseleave', function() {
        tooltip.style.opacity = '0';
        if (dot.dataset.peak === 'true') {
          dot.setAttribute('r', '4');
          dot.setAttribute('fill', 'var(--color-brand)');
          dot.removeAttribute('stroke');
        } else {
          dot.setAttribute('r', '2.5');
          dot.setAttribute('fill', 'var(--color-canvas)');
          dot.setAttribute('stroke', 'var(--color-ink-950)');
        }
      });
    });
  })();
  </script>

  <% } %>
</section>

<!-- Per-project table -->
<section class="table-shell">
  <div style="padding:1rem 1.25rem;border-bottom:1px solid var(--color-border);display:flex;align-items:center;justify-content:space-between">
    <p style="font-size:0.9375rem;font-weight:700;color:var(--color-ink-950)">By project</p>
    <p style="font-size:0.75rem;color:var(--color-ink-500)"><%= days %>-day window</p>
  </div>
  <div class="table-scroll">
    <table class="data-table">
      <thead>
        <tr>
          <th>Project</th>
          <th>Questions</th>
          <th>Avg duration</th>
          <th>Error %</th>
          <th>API calls</th>
          <th>Tokens</th>
          <th>Cost</th>
        </tr>
      </thead>
      <tbody>
        <% if (!perProject.length) { %>
          <tr><td colspan="7" style="text-align:center;color:var(--color-ink-500);padding:2.5rem">No data in this period.</td></tr>
        <% } %>
        <% perProject.forEach(function(row) { %>
        <tr>
          <td>
            <a href="/admin/projects/<%= row.project.id %>/conversations"
               style="font-weight:600;color:var(--color-brand);text-decoration:none">
              <%= row.project.name %>
            </a>
            <div style="font-size:0.75rem;color:var(--color-ink-500);margin-top:0.125rem;font-family:var(--font-mono)"><%= row.project.slug %></div>
          </td>
          <td style="font-weight:600;color:var(--color-ink-950)"><%= row.questions.toLocaleString() %></td>
          <td style="font-family:var(--font-mono);font-size:0.8125rem"><%= row.avgDurationMs != null ? Math.round(row.avgDurationMs).toLocaleString()+'ms' : 'n/a' %></td>
          <td>
            <% if (row.totalRuns) {
                 const errPct = 100 * row.errorRate;
            %>
              <span class="status-badge <%= errPct > 20 ? 'status-error' : (errPct > 0 ? 'status-syncing' : 'status-active') %>">
                <%= errPct.toFixed(1) %>%
              </span>
            <% } else { %>
              <span style="color:var(--color-ink-500);font-size:0.8125rem">n/a</span>
            <% } %>
          </td>
          <td style="font-family:var(--font-mono);font-size:0.8125rem"><%= row.apiCallCount.toLocaleString() %></td>
          <td style="font-family:var(--font-mono);font-size:0.8125rem">
            <%= (row.totalTokensInput != null && row.totalTokensOutput != null) ? (row.totalTokensInput+row.totalTokensOutput).toLocaleString() : 'n/a' %>
          </td>
          <td style="font-family:var(--font-mono);font-size:0.8125rem;color:var(--color-success);font-weight:600">
            <%= row.totalCostUsd != null ? '$'+row.totalCostUsd.toFixed(4) : 'n/a' %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../layout-foot', { layoutShell: 'index' }) %>
