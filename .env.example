# Copy this file to .env and fill in real values. .env is already in .gitignore; do not commit it.

# Public event API port. The public tunnel points here. This app does not include the admin UI.
PORT=6666

# Admin dashboard and /internal/call-api port. Keep it private: bind to 127.0.0.1 and do not tunnel it.
ADMIN_PORT=8667

# OpenCode remote control port. Change this if 4096 is already taken on the host.
OPENCODE_PORT=4096

# Password for OpenCode remote control (http://localhost:4096, or OPENCODE_PORT above).
# Empty means no password. This is safe only when the port is bound to 127.0.0.1.
OPENCODE_SERVER_PASSWORD=

# SQLite DB path. Default: data/otb.sqlite. Docker mounts ./data.
# OTB_DB_PATH=data/otb.sqlite

# Workspace directory for cloned repositories. Default: ./workspaces. Docker mounts ./workspaces.
# OTB_WORKSPACES_DIR=workspaces

# Admin UI login (required). The admin UI refuses to serve pages until both are set.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Set to "true" when the admin UI is served over HTTPS so the session cookie is Secure-only.
# COOKIE_SECURE=true

# Port for the OpenCode UI reverse proxy (admin session required to use it).
# The raw opencode serve port (OPENCODE_PORT) is no longer published to the host.
# OPENCODE_UI_PORT=8668
