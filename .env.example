# Copy file này thành .env rồi điền giá trị thật. .env đã nằm trong .gitignore — KHÔNG commit.

# Port Express (event API + admin UI). Tunnel public trỏ vào port này.
PORT=6666

# Password bảo vệ OpenCode remote control (http://localhost:4096).
# Để trống = không password (chỉ an toàn khi port 4096 chỉ bind 127.0.0.1).
OPENCODE_SERVER_PASSWORD=

# Đường dẫn SQLite DB (mặc định data/otb.sqlite — trong Docker đã mount ./data)
# OTB_DB_PATH=data/otb.sqlite

# Thư mục workspaces chứa repos clone (mặc định ./workspaces — trong Docker đã mount)
# OTB_WORKSPACES_DIR=workspaces
