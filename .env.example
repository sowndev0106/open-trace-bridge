# Copy this file to .env and fill in real values. .env is already in .gitignore; do not commit it.

# Public event API port. The public tunnel points here. This app does not include the admin UI.
PORT=6666

# Admin dashboard and /internal/call-api port. Keep it private: bind to 127.0.0.1 and do not tunnel it.
ADMIN_PORT=8667

# Password for OpenCode remote control (http://localhost:4096).
# Empty means no password. This is safe only when port 4096 is bound to 127.0.0.1.
OPENCODE_SERVER_PASSWORD=

# SQLite DB path. Default: data/otb.sqlite. Docker mounts ./data.
# OTB_DB_PATH=data/otb.sqlite

# Workspace directory for cloned repositories. Default: ./workspaces. Docker mounts ./workspaces.
# OTB_WORKSPACES_DIR=workspaces
